generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String               @id @default(cuid())
  email                 String               @unique
  cpfNormalized         String?              @unique
  phone                 String?
  name                  String?
  firstName             String?
  lastName              String?
  birthDate             DateTime?
  zipCode               String?
  street                String?
  city                  String?
  state                 String?
  emergencyContact      String?
  status                UserStatus           @default(ACTIVE)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  authIdentities        AuthIdentity[]
  passwordCredential    PasswordCredential?
  passwordResetTokens   PasswordResetToken[]
  memberships           AcademyMembership[]
  acceptedInvitations   Invitation[]         @relation("AcceptedInvitationUser")
  enrollmentRequests    EnrollmentRequest[]
  sessions              UserSession[]
  subscriptions         Subscription[]
  subscriptionPlanChanges SubscriptionPlanChange[]
  financeRecurringSetups FinanceRecurringSetup[]
  financeCreditBalances FinanceCreditBalance[]
  teacherProfiles       TeacherProfile[]
  studentProfiles       StudentProfile[]
  financeCharges        FinanceCharge[]
  createdFinanceCoupons FinanceCoupon[]      @relation("CreatedFinanceCouponUser")
  eventParticipants     EventParticipant[]
  graduationEligibilityOverrideAudits GraduationEligibilityOverrideAudit[]
}

model Tenant {
  id                   String                 @id @default(cuid())
  slug                 String                 @unique
  legalName            String
  displayName          String
  status               TenantStatus           @default(ACTIVE)
  brandingJson         Json?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  domains              TenantDomain[]
  memberships          AcademyMembership[]
  invitations          Invitation[]
  enrollmentRequests   EnrollmentRequest[]
  onboarding           TenantOnboarding?
  profile              TenantProfile?
  location             TenantLocation?
  modalities           Modality[]
  teacherProfiles      TeacherProfile[]
  classGroups          ClassGroup[]
  classSessions        ClassSession[]
  branding             TenantBranding?
  paymentSettings      TenantPaymentSettings?
  plans                Plan[]
  subscriptions        Subscription[]
  subscriptionPlanChanges SubscriptionPlanChange[]
  financeRecurringSetups FinanceRecurringSetup[]
  studentProfiles      StudentProfile[]
  financeCreditBalances FinanceCreditBalance[]
  financeCoupons       FinanceCoupon[]
  graduationTracks     GraduationTrack[]
  graduationExams      GraduationExam[]
  financeCharges       FinanceCharge[]
  events               Event[]
  eventParticipants    EventParticipant[]
  site                 TenantSite?
  leads                Lead[]
  marketingBrandKit    MarketingBrandKit?
  marketingAssets      MarketingAsset[]
  marketingGenerations MarketingGeneration[]
  marketingUsageLedger MarketingUsageLedger[]
  marketingAiSettings  MarketingAiSettings?
  athleteTitles        AthleteTitle[]
  graduationEligibilityOverrideAudits GraduationEligibilityOverrideAudit[]
}

model TenantDomain {
  id         String   @id @default(cuid())
  tenantId   String
  domain     String   @unique
  isPrimary  Boolean  @default(false)
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model AcademyMembership {
  id             String           @id @default(cuid())
  userId         String
  tenantId       String
  role           AcademyRole
  status         MembershipStatus @default(PENDING)
  invitedByName  String?
  acceptedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teacherProfile TeacherProfile?
  studentProfile StudentProfile?

  @@unique([userId, tenantId])
  @@index([tenantId, role])
  @@index([userId, status])
}

model Invitation {
  id            String           @id @default(cuid())
  tenantId      String
  email         String
  role          AcademyRole
  token         String           @unique
  status        InvitationStatus @default(PENDING)
  invitedByName String
  acceptedById  String?
  expiresAt     DateTime
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  acceptedBy    User?            @relation("AcceptedInvitationUser", fields: [acceptedById], references: [id])

  @@index([tenantId, email])
  @@index([tenantId, status])
}

model EnrollmentRequest {
  id                   String                  @id @default(cuid())
  tenantId             String
  userId               String
  requestedRole        AcademyRole             @default(STUDENT)
  teacherRoleTitle     String?
  requestedActivityCategories String[]         @default([])
  requestedModalityIds String[]                @default([])
  status               EnrollmentRequestStatus @default(PENDING)
  createdAt            DateTime                @default(now())
  reviewedAt           DateTime?
  updatedAt            DateTime                @updatedAt
  tenant               Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                 User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId, status])
}

model Plan {
  id              String             @id @default(cuid())
  tenantId        String
  name            String
  amountCents     Int
  billingCycle    BillingCycle
  weeklyFrequency Int?
  classLimitKind  PlanClassLimitKind @default(UNLIMITED)
  classLimitValue Int?
  sortOrder       Int                @default(0)
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscriptions   Subscription[]
  subscriptionPlanChangesFrom SubscriptionPlanChange[] @relation("SubscriptionPlanChangeFromPlan")
  subscriptionPlanChangesTo   SubscriptionPlanChange[] @relation("SubscriptionPlanChangeToPlan")
  modalities      PlanModality[]
  financeCharges  FinanceCharge[]
  financeCoupons  FinanceCoupon[]
  financeRecurringSetups FinanceRecurringSetup[]

  @@index([tenantId, isActive])
}

model PlanModality {
  id         String   @id @default(cuid())
  planId     String
  modalityId String
  createdAt  DateTime @default(now())
  plan       Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  modality   Modality @relation(fields: [modalityId], references: [id], onDelete: Cascade)

  @@unique([planId, modalityId])
  @@index([modalityId])
}

model Subscription {
  id             String             @id @default(cuid())
  tenantId       String
  userId         String
  planId         String
  status         SubscriptionStatus @default(PENDING)
  startDate      DateTime
  billingDay     Int                @default(5)
  endDate        DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan           Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  financeCharges FinanceCharge[]
  planChanges    SubscriptionPlanChange[]

  @@index([tenantId, userId])
  @@index([tenantId, status])
}

model StudentProfile {
  id                String                 @id @default(cuid())
  tenantId          String
  userId            String
  membershipId      String?                @unique
  emergencyContact  String?
  notes             String?
  status            StudentProfileStatus   @default(ACTIVE)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  tenant            Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  membership        AcademyMembership?     @relation(fields: [membershipId], references: [id], onDelete: SetNull)
  activities        StudentActivity[]
  modalities        StudentModality[]
  classEnrollments  ClassGroupEnrollment[]
  financeRecurringSetups FinanceRecurringSetup[]
  financeCreditBalance  FinanceCreditBalance?
  financeCharges    FinanceCharge[]
  eventParticipants EventParticipant[]
  athleteTitles     AthleteTitle[]

  @@unique([tenantId, userId])
  @@index([tenantId, status])
}

model StudentActivity {
  id                         String                     @id @default(cuid())
  studentProfileId           String
  activityCategory           String?
  belt                       String
  stripes                    Int                        @default(0)
  graduationEligibleOverride Boolean?
  startDate                  DateTime
  notes                      String?
  status                     StudentActivityStatus      @default(ACTIVE)
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  studentProfile             StudentProfile             @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  modalities                 StudentModality[]
  graduations                StudentGraduation[]
  examCandidates             GraduationExamCandidate[]
  eligibilityOverrideAudits  GraduationEligibilityOverrideAudit[]

  @@unique([studentProfileId, activityCategory])
  @@index([activityCategory, status])
}

model SubscriptionPlanChange {
  id             String                       @id @default(cuid())
  tenantId       String
  userId         String
  subscriptionId String
  fromPlanId     String
  toPlanId       String
  transitionPolicy PlanTransitionPolicy
  chargeHandling PlanTransitionChargeHandling
  effectiveDate  DateTime
  status         SubscriptionPlanChangeStatus @default(PENDING)
  requestedAt    DateTime                     @default(now())
  appliedAt      DateTime?
  updatedAt      DateTime                     @updatedAt
  tenant         Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription   Subscription                 @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  fromPlan       Plan                         @relation("SubscriptionPlanChangeFromPlan", fields: [fromPlanId], references: [id], onDelete: Restrict)
  toPlan         Plan                         @relation("SubscriptionPlanChangeToPlan", fields: [toPlanId], references: [id], onDelete: Restrict)

  @@index([tenantId, status, effectiveDate])
  @@index([tenantId, userId, status])
  @@index([subscriptionId, status])
}

model FinanceCreditBalance {
  id              String         @id @default(cuid())
  tenantId        String
  userId          String
  studentProfileId String?       @unique
  balanceCents    Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentProfile  StudentProfile? @relation(fields: [studentProfileId], references: [id], onDelete: SetNull)

  @@unique([tenantId, userId])
  @@index([tenantId, balanceCents])
}

model FinanceCharge {
  id                  String                 @id @default(cuid())
  tenantId            String
  userId              String
  studentProfileId    String?
  subscriptionId      String?
  recurringSetupId    String?
  planId              String?
  externalKey         String?                @unique
  description         String
  category            String
  amountCents         Int
  originalAmountCents Int?
  discountAmountCents Int                    @default(0)
  discountSource      FinanceDiscountSource?
  discountReason      String?
  dueDate             DateTime
  paidAt              DateTime?
  status              FinanceChargeStatus    @default(PENDING)
  paymentMethod       FinancePaymentMethod?
  notes               String?
  couponId            String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  tenant              Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentProfile      StudentProfile?        @relation(fields: [studentProfileId], references: [id], onDelete: SetNull)
  subscription        Subscription?          @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  recurringSetup      FinanceRecurringSetup? @relation(fields: [recurringSetupId], references: [id], onDelete: SetNull)
  plan                Plan?                  @relation(fields: [planId], references: [id], onDelete: SetNull)
  coupon              FinanceCoupon?         @relation(fields: [couponId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@index([userId, dueDate])
  @@index([couponId])
}

model FinanceRecurringSetup {
  id               String                     @id @default(cuid())
  tenantId         String
  userId           String
  studentProfileId String?
  planId           String?
  source           FinanceRecurringSetupSource
  description      String
  category         String
  amountCents      Int
  billingCycle     BillingCycle
  billingDay       Int
  startDate        DateTime
  isActive         Boolean                    @default(true)
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  tenant           Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentProfile   StudentProfile?            @relation(fields: [studentProfileId], references: [id], onDelete: SetNull)
  plan             Plan?                      @relation(fields: [planId], references: [id], onDelete: SetNull)
  financeCharges   FinanceCharge[]

  @@index([tenantId, isActive])
  @@index([userId, isActive])
  @@index([studentProfileId, isActive])
  @@index([planId])
}

model FinanceCoupon {
  id              String              @id @default(cuid())
  tenantId        String
  code            String
  title           String
  description     String?
  discountType    FinanceDiscountType
  amountCents     Int?
  percentageOff   Int?
  appliesToPlanId String?
  isActive        Boolean             @default(true)
  startsAt        DateTime?
  endsAt          DateTime?
  maxRedemptions  Int?
  redemptionCount Int                 @default(0)
  createdByUserId String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan            Plan?               @relation(fields: [appliesToPlanId], references: [id], onDelete: SetNull)
  createdByUser   User?               @relation("CreatedFinanceCouponUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  financeCharges  FinanceCharge[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@index([appliesToPlanId])
}

model StudentModality {
  id                         String                    @id @default(cuid())
  studentProfileId           String
  studentActivityId          String?
  modalityId                 String
  belt                       String
  stripes                    Int                       @default(0)
  graduationEligibleOverride Boolean?
  startDate                  DateTime
  notes                      String?
  status                     StudentModalityStatus     @default(ACTIVE)
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt
  studentProfile             StudentProfile            @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  studentActivity            StudentActivity?          @relation(fields: [studentActivityId], references: [id], onDelete: SetNull)
  modality                   Modality                  @relation(fields: [modalityId], references: [id], onDelete: Cascade)

  @@unique([studentProfileId, modalityId])
  @@index([modalityId, status])
  @@index([studentActivityId])
}

model GraduationEligibilityOverrideAudit {
  id                   String          @id @default(cuid())
  tenantId             String
  studentActivityId    String
  actorUserId          String?
  actorName            String?
  actorRole            AcademyRole
  eligibleOverrideValue Boolean
  createdAt            DateTime        @default(now())
  tenant               Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentActivity      StudentActivity @relation(fields: [studentActivityId], references: [id], onDelete: Cascade)
  actorUser            User?           @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([studentActivityId, createdAt])
  @@index([actorUserId])
}

model StudentGraduation {
  id                String          @id @default(cuid())
  studentActivityId String
  fromBelt          String?
  fromStripes       Int?
  toBelt            String
  toStripes         Int             @default(0)
  evaluatorName     String
  graduatedAt       DateTime
  notes             String?
  createdAt         DateTime        @default(now())
  studentActivity   StudentActivity @relation(fields: [studentActivityId], references: [id], onDelete: Cascade)

  @@index([studentActivityId, graduatedAt])
}

model GraduationTrack {
  id          String                @id @default(cuid())
  tenantId    String
  modalityId  String?
  name        String
  branch      GraduationTrackBranch
  progression GraduationProgression @default(BELT)
  sortOrder   Int                   @default(0)
  isDefault   Boolean               @default(false)
  isActive    Boolean               @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  tenant      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  modality    Modality?             @relation(fields: [modalityId], references: [id], onDelete: SetNull)
  levels      GraduationLevel[]
  exams       GraduationExam[]

  @@unique([tenantId, modalityId, name, branch, progression])
  @@index([tenantId, sortOrder])
  @@index([tenantId, modalityId])
}

model GraduationLevel {
  id            String          @id @default(cuid())
  trackId       String
  name          String
  colorHex      String
  stripes       Int             @default(0)
  minTimeMonths Int?
  sortOrder     Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  track         GraduationTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([trackId, sortOrder])
}

model GraduationExam {
  id             String                    @id @default(cuid())
  tenantId       String
  trackId        String
  modalityId     String?
  title          String
  examDate       DateTime
  location       String?
  evaluatorName  String?
  evaluatorNames String[]                  @default([])
  trackIds       String[]                  @default([])
  allTracks      Boolean                   @default(false)
  allEvaluators  Boolean                   @default(false)
  notes          String?
  status         GraduationExamStatus      @default(SCHEDULED)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  tenant         Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  track          GraduationTrack           @relation(fields: [trackId], references: [id], onDelete: Cascade)
  modality       Modality?                 @relation(fields: [modalityId], references: [id], onDelete: SetNull)
  candidates     GraduationExamCandidate[]

  @@index([tenantId, examDate])
  @@index([trackId, examDate])
}

model GraduationExamCandidate {
  id                String          @id @default(cuid())
  examId            String
  studentActivityId String
  fromBelt          String?
  fromStripes       Int?            @default(0)
  toBelt            String?
  toStripes         Int             @default(0)
  attendanceRate    Int             @default(0)
  techniquesScore   Int?
  behavior          String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  exam              GraduationExam  @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentActivity   StudentActivity @relation(fields: [studentActivityId], references: [id], onDelete: Cascade)

  @@unique([examId, studentActivityId])
  @@index([studentActivityId])
}

model AuthIdentity {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerSubjectId String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubjectId])
  @@index([userId])
}

model PasswordCredential {
  id           String   @id @default(cuid())
  userId       String   @unique
  passwordHash String
  passwordSalt String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSession {
  id               String   @id @default(cuid())
  userId           String
  sessionTokenHash String   @unique
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model TenantOnboarding {
  id                 String           @id @default(cuid())
  tenantId           String           @unique
  status             OnboardingStatus @default(DRAFT)
  currentStep        Int              @default(1)
  completedSteps     String[]         @default([])
  academyInfoJson    Json?
  locationJson       Json?
  classStructureJson Json?
  teachersSetupJson  Json?
  plansSetupJson     Json?
  brandingSetupJson  Json?
  paymentsSetupJson  Json?
  completedAt        DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantProfile {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  phone        String?
  contactEmail String?
  description  String?
  document     String?
  foundedYear  Int?
  website      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantLocation {
  id         String   @id @default(cuid())
  tenantId   String   @unique
  zipCode    String?
  street     String?
  number     String?
  complement String?
  city       String?
  state      String?
  country    String   @default("Brasil")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Modality {
  id                     String            @id @default(cuid())
  tenantId               String
  activityCategory       String?
  name                   String
  ageGroups              AgeGroup[]
  defaultDurationMinutes Int
  defaultCapacity        Int
  sortOrder              Int               @default(0)
  isActive               Boolean           @default(true)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  tenant                 Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planLinks              PlanModality[]
  classGroups            ClassGroup[]
  teacherLinks           TeacherModality[]
  studentLinks           StudentModality[]
  graduationTracks       GraduationTrack[]
  graduationExams        GraduationExam[]
  events                 Event[]
  leads                  Lead[]

  @@index([tenantId, activityCategory, sortOrder])
}

model Lead {
  id                String     @id @default(cuid())
  tenantId          String
  modalityId        String?
  name              String
  email             String?
  phone             String
  source            LeadSource
  status            LeadStatus @default(NEW)
  interestLabel     String?
  notes             String?
  sourceContext     String?
  consentAcceptedAt DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  tenant            Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  modality          Modality?  @relation(fields: [modalityId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([tenantId, source])
  @@index([modalityId])
}

model TeacherProfile {
  id                  String                     @id @default(cuid())
  tenantId            String
  userId              String?
  membershipId        String?                    @unique
  name                String
  email               String?
  phone               String?
  rank                String?
  roleTitle           String?
  specialty           String?
  status              TeacherProfileStatus       @default(DRAFT)
  profileCompleteness TeacherProfileCompleteness @default(PENDING_PAYMENT_DETAILS)
  sortOrder           Int                        @default(0)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  tenant              Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                User?                      @relation(fields: [userId], references: [id], onDelete: SetNull)
  membership          AcademyMembership?         @relation(fields: [membershipId], references: [id], onDelete: SetNull)
  classGroups         ClassGroup[]
  modalities          TeacherModality[]
  graduations         TeacherGraduation[]
  compensation        TeacherCompensation?
  organizedEvents     Event[]
  eventParticipants   EventParticipant[]
  athleteTitles       AthleteTitle[]

  @@index([tenantId, sortOrder])
  @@index([tenantId, userId])
}

model AthleteTitle {
  id               String         @id @default(cuid())
  tenantId         String
  studentProfileId String?
  teacherProfileId String?
  placement        AthleteTitlePlacement?
  title            String
  competition      String
  year             Int
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentProfile   StudentProfile? @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  teacherProfile   TeacherProfile? @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)

  @@index([tenantId, year])
