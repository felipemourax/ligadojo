  fromStripes      Int?
  toBelt           String
  toStripes        Int            @default(0)
  graduatedAt      DateTime
  notes            String?
  createdAt        DateTime       @default(now())
  teacherProfile   TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)

  @@index([teacherProfileId, graduatedAt])
  @@index([activityCategory, graduatedAt])
}

model ClassGroup {
  id               String                 @id @default(cuid())
  tenantId         String
  modalityId       String?
  teacherProfileId String?
  name             String
  modalityName     String
  teacherName      String
  ageGroups        AgeGroup[]
  beltRange        String
  maxStudents      Int
  currentStudents  Int                    @default(0)
  status           ClassGroupStatus       @default(ACTIVE)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  tenant           Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  modality         Modality?              @relation(fields: [modalityId], references: [id], onDelete: SetNull)
  teacherProfile   TeacherProfile?        @relation(fields: [teacherProfileId], references: [id], onDelete: SetNull)
  enrollments      ClassGroupEnrollment[]
  schedules        ClassSchedule[]
  sessions         ClassSession[]

  @@index([tenantId, status])
  @@index([modalityId])
  @@index([teacherProfileId])
}

model ClassGroupEnrollment {
  id               String                     @id @default(cuid())
  classGroupId     String
  studentProfileId String
  status           ClassGroupEnrollmentStatus @default(ACTIVE)
  joinedAt         DateTime                   @default(now())
  leftAt           DateTime?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  classGroup       ClassGroup                 @relation(fields: [classGroupId], references: [id], onDelete: Cascade)
  studentProfile   StudentProfile             @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@unique([classGroupId, studentProfileId])
  @@index([classGroupId, status])
  @@index([studentProfileId, status])
}

model ClassSchedule {
  id           String     @id @default(cuid())
  classGroupId String
  weekday      Int
  startTime    String
  endTime      String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  classGroup   ClassGroup @relation(fields: [classGroupId], references: [id], onDelete: Cascade)

  @@index([classGroupId, weekday])
}

model ClassSession {
  id                    String             @id @default(cuid())
  tenantId              String
  classGroupId          String
  sessionDate           DateTime
  weekday               Int
  startTime             String
  endTime               String
  status                ClassSessionStatus @default(SCHEDULED)
  confirmedStudentIds   String[]           @default([])
  confirmedStudentNames String[]           @default([])
  presentStudentIds     String[]           @default([])
  absentStudentIds      String[]           @default([])
  justifiedStudentIds   String[]           @default([])
  finalizedAt           DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  tenant                Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classGroup            ClassGroup         @relation(fields: [classGroupId], references: [id], onDelete: Cascade)

  @@unique([classGroupId, sessionDate])
  @@index([tenantId, sessionDate])
}

model Event {
  id                     String             @id @default(cuid())
  tenantId               String
  modalityId             String?
  teacherProfileId       String?
  name                   String
  type                   EventType
  eventDate              DateTime
  startTime              String
  location               String
  organizerName          String?
  modalityName           String
  status                 EventStatus        @default(SCHEDULED)
  capacity               Int                @default(0)
  registrationsOpen      Boolean            @default(true)
  hasRegistrationFee     Boolean            @default(false)
  registrationFeeCents   Int?
  registrationFeeDueDays Int?
  notes                  String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  tenant                 Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  modality               Modality?          @relation(fields: [modalityId], references: [id], onDelete: SetNull)
  teacherProfile         TeacherProfile?    @relation(fields: [teacherProfileId], references: [id], onDelete: SetNull)
  participants           EventParticipant[]

  @@index([tenantId, eventDate])
  @@index([tenantId, status])
  @@index([modalityId])
  @@index([teacherProfileId])
}

model EventParticipant {
  id               String                 @id @default(cuid())
  tenantId         String
  eventId          String
