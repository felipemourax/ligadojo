  teacherProfile   TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  modality         Modality       @relation(fields: [modalityId], references: [id], onDelete: Cascade)

  @@unique([teacherProfileId, modalityId])
  @@index([modalityId])
}

model TeacherCompensation {
  id               String                  @id @default(cuid())
  teacherProfileId String                  @unique
  type             TeacherCompensationType
  amountCents      Int
